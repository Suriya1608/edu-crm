APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=edu_crm
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ─── Queue ────────────────────────────────────────────────────────────────────
# Use 'redis' on production (requires Redis + Horizon).
# Use 'database' for local development without Redis.
QUEUE_CONNECTION=redis

# ─── Cache ────────────────────────────────────────────────────────────────────
# Use 'redis' on production for in-memory speed.
# Use 'database' or 'file' for local development without Redis.
CACHE_STORE=redis
# CACHE_PREFIX=

# ─── Redis ────────────────────────────────────────────────────────────────────
# On Windows (WAMP/Laragon): install Redis for Windows or use WSL.
# Use REDIS_CLIENT=predis (no PHP extension needed, pure PHP).
# Use REDIS_CLIENT=phpredis for better performance on Linux (requires ext-redis).
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MEMCACHED_HOST=127.0.0.1

# ─── Sanctum (API Tokens) ─────────────────────────────────────────────────────
# Token expiration in minutes. 1440 = 24 hours. null = never expires.
SANCTUM_TOKEN_EXPIRATION=1440
# Comma-separated domains allowed to use cookie-based (SPA) auth
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# ─── Horizon (Queue Dashboard) ────────────────────────────────────────────────
# Access: {APP_URL}/horizon  (admin role required in production)
HORIZON_NAME="${APP_NAME} Horizon"
# HORIZON_PATH=horizon
# HORIZON_DOMAIN=
HORIZON_ALERT_EMAIL=
HORIZON_SLACK_WEBHOOK=
HORIZON_SLACK_CHANNEL=#crm-ops

# Queue health-check monitor (artisan queue:health-check)
QUEUE_MONITOR_ALERT_EMAIL=
QUEUE_MONITOR_SLACK_WEBHOOK=
QUEUE_MONITOR_SLACK_CHANNEL=#crm-ops
QUEUE_MONITOR_QUEUES=default,notifications,emails,high
QUEUE_MONITOR_DEFAULT_MAX_PENDING=300
QUEUE_MONITOR_MAX_PENDING_DEFAULT=300
QUEUE_MONITOR_MAX_PENDING_NOTIFICATIONS=500
QUEUE_MONITOR_MAX_PENDING_EMAILS=200
QUEUE_MONITOR_MAX_PENDING_HIGH=100
QUEUE_MONITOR_MAX_FAILED_JOBS=20
QUEUE_MONITOR_ALERT_COOLDOWN_SECONDS=300

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

DEFAULT_COUNTRY_CODE=+91
GEO_LOOKUP_BASE_URL=https://ipwho.is

# Comma-separated list of frontend origins allowed to call public lead-capture endpoints.
# Example: https://landing.example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1:8000

# Shared secret required for public lead-capture endpoints.
# Send via `X-Lead-Capture-Token` header (or Bearer token).
LEAD_CAPTURE_SHARED_SECRET=

# Meta WhatsApp Business Cloud API
META_WHATSAPP_TOKEN=your_meta_whatsapp_token_here
META_WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=crm_verify_token
META_WHATSAPP_DEFAULT_TEMPLATE=welcome_template
META_WHATSAPP_DEFAULT_TEMPLATE_LANGUAGE=en_US
